{
  "name": "influx-mcp",
  "description": "MCP server para consultar InfluxDB (v2/v1) con herramientas IoT",
  "command": ["python", "-m", "influx_mcp.server"],
  "env": [
    "INFLUX_VERSION",
    "INFLUX_URL",
    "INFLUX_ORG",
    "INFLUX_TOKEN",
    "INFLUX_DEFAULT_BUCKET",
    "INFLUX_USERNAME",
    "INFLUX_PASSWORD",
    "INFLUX_DEFAULT_DB",
    "INFLUX_DEFAULT_RP",
    "INFLUX_REQUEST_TIMEOUT_SEC",
    "MCP_LOG_LEVEL"
  ]
}
